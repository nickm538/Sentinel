# Sentinel Trap v4 — environment variables
#
# Copy these into Railway's "Variables" tab (or any other host). The backend
# (`server-index.js`) reads each one via `process.env.<NAME>`; names below are
# the exact strings it looks for.

# --- Required --------------------------------------------------------------

# Postgres connection string. On Railway, add the Postgres plugin and reference
# it as:  ${{ Postgres.DATABASE_URL }}
DATABASE_URL=postgres://user:password@host:5432/dbname

# Password for the admin portal (HTTP Basic auth; the username is ignored).
# Use a long random string. If unset the server fails closed with HTTP 503 on
# every admin route, so this MUST be set.
ADMIN_PASS=change-me-to-a-long-random-string

# --- Optional / recommended frontend access control ------------------------

# Comma-separated list of origins allowed for CORS and socket.io. Set this if
# your frontend is served from a different origin than the backend. If unset,
# cross-origin requests are rejected, but same-origin requests still work.
# Include the full scheme + host.
#   e.g. https://sentinel.up.railway.app,https://admin.example.com
ALLOWED_ORIGINS=https://your-app.up.railway.app

# --- Optional enrichment API keys ------------------------------------------
# Each is independent. Missing keys just skip that enrichment field; the
# click is still recorded and shown in the admin portal.

# ipinfo.io — country / ASN / org lookup for the scammer's IP.
IPINFO_TOKEN=

# AbuseIPDB — abuse-confidence score for the scammer's IP.
ABUSEIPDB_KEY=

# OpenRouter — AI-generated probabilistic scammer profile. See
# https://openrouter.ai/models for valid model slugs.
OPENROUTER_KEY=
# Optional: override the model. Defaults to openai/gpt-5.2.
OPENROUTER_MODEL=openai/gpt-5.2
# Optional: sent as the HTTP-Referer header to OpenRouter (attribution / rate
# limit tier). Defaults to the GitHub repo URL.
OPENROUTER_REFERER=

# Trestle — reverse-phone enrichment (caller_id, phone_intel, cnam). Runs
# automatically on every /api/track that includes a `phone` field in the body
# (typically supplied by the bait page as a `?phone=` query param that it
# forwards into the POST). If TRESTLE_KEY is unset or no phone is present,
# Trestle is simply skipped — clicks are still recorded.
TRESTLE_KEY=

# Apify — deep/dark-web actor that is "resurrected" on every click with a
# fresh, per-click INPUT (IP, phone, hostnames, ipinfo, WebRTC IPs, trapId)
# written to the actor's default key-value store. Fire-and-forget; the run
# handle is stored on the click. Admin-gated endpoints exist for inspection:
#   GET  /api/apify-run/:runId
#   GET  /api/apify-run/:runId/input
#   GET  /api/apify-run/:runId/log
#   POST /api/apify-run/:runId/resurrect
APIFY_TOKEN=
# The actor run to resurrect. Get this from the Apify console URL
# (/actors/<id>/runs/<runId>) or from an existing GET /v2/actor-runs response.
APIFY_ACTOR_RUN_ID=

# BrowserLeaks WebRTC — opt-in, agentic scrape of browserleaks.com/webrtc via
# headless Chromium (Playwright). Admin-gated endpoint:
#   GET /api/browserleaks/webrtc
# Note: the IPs that page reports belong to the Sentinel *server*, not the
# scammer, so this is mainly a diagnostic / baseline tool. Requires:
#   npm install playwright  &&  npx playwright install --with-deps chromium
# on the Railway image, then set the flag below.
BROWSERLEAKS_ENABLED=

# --- Managed by the platform ----------------------------------------------
# PORT is injected by Railway / Heroku / Render automatically; the server
# falls back to 3000 for local dev. You normally do NOT set this yourself.
# PORT=3000
